# RSSHub Environment Configuration Example
# Copy this file to .env and configure as needed

# ========================
# Application Settings
# ========================

# Disable robots.txt detection
# DISALLOW_ROBOT=

# Enable cluster mode
# ENABLE_CLUSTER=

# Node instance name
# NODE_NAME=

# Playwright WebSocket endpoint for remote browser control
# PLAYWRIGHT_WS_ENDPOINT=

# Puppeteer WebSocket endpoint for remote browser control
# PUPPETEER_WS_ENDPOINT=

# Custom Chromium executable path
# CHROMIUM_EXECUTABLE_PATH=

# ========================
# Network Configuration
# ========================

# Server port (default: 1200)
# PORT=1200

# Listen on all interfaces (default: true)
# LISTEN_INADDR_ANY=true

# Disable IPv6 support
# DISABLE_IPV6=

# Request retry count (default: 3)
# REQUEST_RETRY=3

# Request timeout in milliseconds (default: 10000)
# REQUEST_TIMEOUT=10000

# Custom User-Agent string
# UA=

# Disable random User-Agent rotation
# NO_RANDOM_UA=

# Allowed origins for CORS (comma-separated)
# ALLOW_ORIGIN=

# ========================
# Cache Configuration
# ========================

# Cache type: memory, redis, file, mysql, postgresql (default: memory)
# CACHE_TYPE=memory

# Cache request timeout in milliseconds
# CACHE_REQUEST_TIMEOUT=

# Cache expire time in seconds (default: 300)
# CACHE_EXPIRE=300

# Cache content expire time in seconds (default: 600)
# CACHE_CONTENT_EXPIRE=600

# Maximum memory for cache in bytes (e.g., 1gb)
# MEMORY_MAX=

# Redis connection URL
# REDIS_URL=

# HTTP cache URL
# CACHE_HTTP_URL=

# HTTP cache token
# CACHE_HTTP_TOKEN=

# ========================
# Proxy Configuration
# ========================

# Single proxy URI (e.g., socks5://127.0.0.1:1080)
# PROXY_URI=

# Multiple proxy URIs (comma-separated)
# PROXY_URIS=

# Proxy protocol
# PROXY_PROTOCOL=

# Proxy host
# PROXY_HOST=

# Proxy port
# PROXY_PORT=

# Proxy authentication (username:password)
# PROXY_AUTH=

# URL regex pattern for proxy
# PROXY_URL_REGEX=

# Proxy strategy: ChooseRandom, Fixed, RoundRobin, RandomRoundRobin (default: Fixed)
# PROXY_STRATEGY=Fixed

# Proxy failover timeout in seconds
# PROXY_FAILOVER_TIMEOUT=

# Proxy health check interval in seconds
# PROXY_HEALTH_CHECK_INTERVAL=

# PAC file URI
# PAC_URI=

# PAC script content
# PAC_SCRIPT=

# ========================
# Access Control
# ========================

# Access key for API authentication
# ACCESS_KEY=

# ========================
# Logging Configuration
# ========================

# Enable debug info display
# DEBUG_INFO=

# Logger level: error, warn, info, debug (default: info)
# LOGGER_LEVEL=info

# Disable log files
# NO_LOGFILES=

# OpenTelemetry buckets
# OTEL_SECONDS_BUCKET=
# OTEL_MILLISECONDS_BUCKET=

# Show timestamp in logs
# SHOW_LOGGER_TIMESTAMP=

# Honeybadger API key
# HONEYBADGER_API_KEY=

# Error tracking route timeout
# ERROR_TRACKING_ROUTE_TIMEOUT=

# Sentry DSN URL
# SENTRY=

# Sentry route timeout
# SENTRY_ROUTE_TIMEOUT=

# Enable remote debugging
# ENABLE_REMOTE_DEBUGGING=

# ========================
# Feed Configuration
# ========================

# Hotlink template for images (e.g., https://example.com/image?url={url})
# HOTLINK_TEMPLATE=

# Paths to include in hotlink processing
# HOTLINK_INCLUDE_PATHS=

# Paths to exclude from hotlink processing
# HOTLINK_EXCLUDE_PATHS=

# Allow user-defined hotlink template
# ALLOW_USER_HOTLINK_TEMPLATE=

# Filter regex engine: quick-regex, re2, regexp (default: re2)
# FILTER_REGEX_ENGINE=re2

# Allow user to supply unsafe domain
# ALLOW_USER_SUPPLY_UNSAFE_DOMAIN=

# Disable NSFW content
# DISABLE_NSFW=

# Suffix for feed title
# SUFFIX=

# Title length limit
# TITLE_LENGTH_LIMIT=

# ========================
# OpenAI Configuration
# ========================

# OpenAI API Key
# OPENAI_API_KEY=

# OpenAI model (e.g., gpt-3.5-turbo, gpt-4)
# OPENAI_MODEL=gpt-3.5-turbo

# OpenAI temperature (0-2, default: 0.7)
# OPENAI_TEMPERATURE=0.7

# OpenAI max tokens
# OPENAI_MAX_TOKENS=

# OpenAI API endpoint
# OPENAI_API_ENDPOINT=

# OpenAI input option
# OPENAI_INPUT_OPTION=

# OpenAI prompt
# OPENAI_PROMPT=

# OpenAI prompt for title
# OPENAI_PROMPT_TITLE=

# ========================
# Follow Integration
# ========================

# Follow owner user ID
# FOLLOW_OWNER_USER_ID=

# Follow description
# FOLLOW_DESCRIPTION=

# Follow price
# FOLLOW_PRICE=

# Follow user limit
# FOLLOW_USER_LIMIT=

# ========================
# Route-Specific Configuration
# ========================

# Bilibili cookies
# BILIBILI_COOKIE_USER=
# BILIBILI_DM_IMG_LIST=
# BILIBILI_DM_IMG_INTER=
# BILIBILI_EXCLUDE_SUBTITLES=

# GitHub token
# GITHUB_ACCESS_TOKEN=

# Twitter cookies and tokens
# TWITTER_COOKIES=

# YouTube cookies
# YOUTUBE_COOKIES=

# Instagram credentials
# IG_USERNAME=
# IG_PASSWORD=
# IG_PROXY=
# IG_COOKIE=

# Pinterest cookies
# PINTEREST_COOKIES=

# Telegram bot token
# TELEGRAM_TOKEN=
# TELEGRAM_SESSION=

# Spotify credentials
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESHTOKEN=

# Notion integration
# NOTION_TOKEN=

# Netease Cloud Music cookies
# NCM_COOKIES=

# Pixiv credentials
# PIXIV_REFRESHTOKEN=

# Fanbox session
# FANBOX_SESSION_ID=

# Fantia cookie
# FANTIA_COOKIE=

# Discogs credentials
# DISCOGS_API_KEY=
# DISCOGS_API_SECRET=

# Last.fm API key
# LASTFM_API_KEY=

# Reddit credentials
# REDDIT_SESSION_COOKIE=

# Patreon credentials
# PATREON_SESSION_ID=

# Twitch credentials
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# Steam API key
# STEAM_API_KEY=
